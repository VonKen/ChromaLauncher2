<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/background_line"
    android:paddingHorizontal="@dimen/padding_medium"
    android:paddingVertical="@dimen/padding_moderate"
    android:layout_marginVertical="@dimen/padding_small">

    <TextView
        android:id="@+id/mod_item_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="@color/primary_text"
        android:textSize="@dimen/_12ssp"
        app:layout_constraintEnd_toStartOf="@+id/mod_item_toggle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:text="example-mod-1.0.0.jar" />

    <TextView
        android:id="@+id/mod_item_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="@dimen/_9ssp"
        android:textColor="@color/minebutton_color"
        app:layout_constraintEnd_toStartOf="@+id/mod_item_toggle"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginEnd="@dimen/padding_small"
        tools:text="Enabled" />

    <ImageButton
        android:id="@+id/mod_item_toggle"
        android:layout_width="@dimen/_36sdp"
        android:layout_height="@dimen/_36sdp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:scaleType="centerInside"
        android:contentDescription="@string/instance_mods_enable"
        app:layout_constraintEnd_toStartOf="@+id/mod_item_delete"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <ImageButton
        android:id="@+id/mod_item_delete"
        android:layout_width="@dimen/_36sdp"
        android:layout_height="@dimen/_36sdp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_px_delete"
        android:scaleType="centerInside"
        android:contentDescription="@string/global_delete"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
